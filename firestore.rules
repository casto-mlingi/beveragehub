rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.companyId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.companyId == request.auth.uid;
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated() && resource.data.companyId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.companyId != null;
      allow update, delete: if isAuthenticated() && resource.data.companyId == request.auth.uid;
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && resource.data.companyId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.companyId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.companyId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.companyId == request.auth.uid ||
        resource.data.customerName == request.auth.token.name ||
        resource.data.customerUid == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.companyId != null;
      allow update, delete: if isAuthenticated() && resource.data.companyId == request.auth.uid;
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated() && resource.data.companyId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.companyId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.companyId == request.auth.uid;
    }

    match /vendors/{vendorId} {
      allow read: if isAuthenticated() && resource.data.companyId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.companyId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.companyId == request.auth.uid;
    }
  }
}
